# =============================================================================
# network-monitoring-telegraf / .gitignore
#
# 목적: Git 추적에서 제외할 파일 및 디렉토리 목록
#
# 원칙:
#   - 크리덴셜 및 민감 정보가 포함된 파일은 절대 추적하지 않음
#   - 로컬 환경에 종속된 파일은 추적하지 않음
#   - .env.example 은 추적 대상 (실제 값 미포함 템플릿)
# =============================================================================


# -----------------------------------------------------------------------------
# 환경변수 및 크리덴셜
#
# - .env : 실제 크리덴셜이 포함된 환경변수 파일 (절대 커밋 금지)
# - .env.*.local : 로컬 오버라이드용 환경변수 파일
# - .env.example 은 제외 대상 아님 (템플릿으로 커밋 대상)
# -----------------------------------------------------------------------------
.env
.env.*.local


# -----------------------------------------------------------------------------
# Zabbix PSK 키 파일
#
# - PSK(Pre-Shared Key) 파일은 민감 정보이므로 추적 제외
# - 키 파일은 별도 안전한 경로에 보관
# -----------------------------------------------------------------------------
*.psk


# -----------------------------------------------------------------------------
# Python
#
# - __pycache__ : Python 바이트코드 캐시 디렉토리
# - *.pyc       : 컴파일된 바이트코드 파일
# - *.pyo       : 최적화된 바이트코드 파일
# - .venv/      : 가상환경 디렉토리 (로컬 환경 종속)
# - venv/       : 가상환경 디렉토리 (대체 명칭)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/


# -----------------------------------------------------------------------------
# Docker
#
# - docker-compose.override.yml : 로컬 오버라이드 설정 (개인 환경 종속)
# - docker-compose.prod.yml     : Stage 2 운영 배포 파일 (별도 관리)
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.prod.yml


# -----------------------------------------------------------------------------
# Grafana
#
# - grafana/data/ : Grafana 런타임 데이터 (로컬 볼륨 마운트 시 생성될 수 있음)
# -----------------------------------------------------------------------------
grafana/data/


# -----------------------------------------------------------------------------
# InfluxDB
#
# - influxdb/data/ : InfluxDB 런타임 데이터 (로컬 볼륨 마운트 시 생성될 수 있음)
# -----------------------------------------------------------------------------
influxdb/data/


# -----------------------------------------------------------------------------
# 로그 파일
#
# - *.log : 애플리케이션 로그 파일
# - logs/ : 로그 디렉토리
# -----------------------------------------------------------------------------
*.log
logs/


# -----------------------------------------------------------------------------
# 에디터 및 IDE
#
# - .vscode/   : VSCode 워크스페이스 설정 (개인 환경 종속)
#   단, .vscode/extensions.json 은 팀 공유용으로 추적할 수 있음
# - .idea/     : JetBrains IDE 설정
# - *.swp      : Vim 스왑 파일
# - *.swo      : Vim 스왑 파일 (대체 확장자)
# - *~         : 백업 파일 (Emacs 등)
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# OS 생성 파일
#
# - .DS_Store     : macOS Finder 메타데이터
# - Thumbs.db     : Windows 썸네일 캐시
# - desktop.ini   : Windows 폴더 설정 파일
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini