# =============================================================================
# network-monitoring-telegraf / .env.example
#
# 목적: docker-compose.yml 에서 참조하는 환경변수 템플릿
#
# 사용 방법:
#   1. 이 파일을 복사하여 .env 파일 생성
#      cp .env.example .env
#   2. .env 파일의 각 항목에 실제 값 입력
#   3. .env 파일은 절대 Git 에 커밋하지 않을 것 (.gitignore 에 등록됨)
#
# 주의사항:
#   - 이 파일(.env.example)은 Git 에 커밋하여 팀원과 공유 (실제 값 미포함)
#   - 실제 값이 입력된 .env 파일은 .gitignore 로 추적 제외
#   - 각 항목의 생성 방법은 하단 주석 참고
# =============================================================================


# -----------------------------------------------------------------------------
# InfluxDB 설정
#
# - docker-compose.yml 의 influxdb 서비스 초기화에 사용
# - INFLUXDB_TOKEN 은 Telegraf(쓰기) 및 Grafana(읽기) 인증에 공통 사용
# -----------------------------------------------------------------------------

# InfluxDB 관리자 계정 (Web UI 및 CLI 로그인에 사용)
INFLUXDB_USERNAME=admin

# InfluxDB 관리자 비밀번호 (12자 이상 권장)
# 생성 예시: openssl rand -base64 12
INFLUXDB_PASSWORD=changeme_12chars

# InfluxDB 조직명 (Telegraf 출력 및 Grafana 데이터소스 설정과 일치해야 함)
INFLUXDB_ORG=homelab

# InfluxDB 버킷명 (메트릭이 저장되는 논리적 단위)
INFLUXDB_BUCKET=network-metrics

# InfluxDB API 토큰 (32자 이상 랜덤 문자열 권장)
# 생성 예시: openssl rand -hex 32
INFLUXDB_TOKEN=changeme_replace_with_32char_random_token


# -----------------------------------------------------------------------------
# Grafana 설정
#
# - Grafana Web UI 관리자 계정 및 보안 설정
# - GRAFANA_SECRET_KEY 는 세션 쿠키 서명에 사용 (노출 시 세션 탈취 위험)
# -----------------------------------------------------------------------------

# Grafana 관리자 계정 (Web UI 로그인에 사용)
GRAFANA_ADMIN_USER=admin

# Grafana 관리자 비밀번호 (12자 이상 권장)
# 생성 예시: openssl rand -base64 12
GRAFANA_ADMIN_PASSWORD=changeme_12chars

# Grafana 세션 서명용 시크릿 키
# 생성 예시: openssl rand -base64 24
GRAFANA_SECRET_KEY=changeme_replace_with_base64_secret


# -----------------------------------------------------------------------------
# Cisco ACI APIC 접속 정보
#
# - aci_collector.py 가 APIC REST API 호출 시 사용
# - Read-only 전용 계정 사용 권장 (최소 권한 원칙)
# - APIC_URL 은 https:// 포함한 전체 URL 입력
# -----------------------------------------------------------------------------

# ACI APIC URL (https:// 포함)
APIC_URL=https://your-apic-ip

# ACI APIC Read-only 계정명
APIC_USERNAME=readonly_user

# ACI APIC 비밀번호
APIC_PASSWORD=changeme


# -----------------------------------------------------------------------------
# SNMPv3 인증 정보
#
# - Cisco IOS, NX-OS 메트릭 수집에 사용 (v0.4.1 이후 적용)
# - 인증 방식: AuthPriv (인증 + 암호화 모두 적용)
# - 인증 알고리즘: SHA
# - 암호화 알고리즘: AES128
# - SNMP_AUTH_PASSWORD: 8자 이상 (SHA 인증 비밀번호)
# - SNMP_PRIV_PASSWORD: 8자 이상 (AES128 암호화 비밀번호)
# -----------------------------------------------------------------------------

# SNMPv3 사용자명 (장비에 설정된 SNMPv3 사용자명과 일치해야 함)
SNMP_AUTH_USERNAME=snmpv3user

# SNMPv3 SHA 인증 비밀번호 (8자 이상)
SNMP_AUTH_PASSWORD=changeme_auth

# SNMPv3 AES128 암호화 비밀번호 (8자 이상)
SNMP_PRIV_PASSWORD=changeme_priv


# -----------------------------------------------------------------------------
# SNMPv2c Community String (EVE-NG 테스트 환경 전용)
#
# - v0.4.0: EVE-NG vIOS / vNX-OS SNMPv2c 연동 동작 확인에 사용
# - v0.4.1: SNMPv3 전환 후 이 값은 비워도 무방
# - 실 운영망에는 SNMPv2c 사용 금지 (보안상 SNMPv3 AuthPriv 사용 원칙)
# - 장비 측 community string 과 반드시 일치해야 함
# -----------------------------------------------------------------------------

# SNMPv2c Community String (장비에 설정한 community string 과 동일하게 입력)
SNMP_COMMUNITY=public

# -----------------------------------------------------------------------------
# Slack 알림 설정 (v1.1.0)
#
# - slack_notify.py (Flask 서버) 가 Slack Incoming Webhook URL 로 메시지 전송
# - Slack Webhook URL 발급 방법:
#     1. https://api.slack.com/apps → Create New App → From scratch
#     2. Incoming Webhooks → Activate Incoming Webhooks → On
#     3. Add New Webhook to Workspace → 채널 선택
#     4. 생성된 URL 복사 (https://hooks.slack.com/services/... 형식)
# -----------------------------------------------------------------------------

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL